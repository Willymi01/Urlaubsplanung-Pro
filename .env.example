# Ersten Administrator nur beim erstmaligen Erstellen der Datenbank anlegen.
ADMIN_NAME=Admin
ADMIN_PIN=1234

# Vor dem produktiven Einsatz durch einen langen zufälligen Wert ersetzen.
SESSION_SECRET=bitte-einen-langen-zufaelligen-wert-eintragen

# Lokal false; hinter HTTPS im Produktivbetrieb true.
HTTPS_ONLY=false

# Lokale Standarddatenbank. Die Datei liegt absichtlich im ignorierten data-Ordner.
DATABASE_URL=sqlite:///./data/urlaubplaner.db
